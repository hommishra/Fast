{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "A news story, editorial, or dispatch",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "slug": { "type": "string" },
        "featuredImage": { "type": "string" },
        "status": { "type": "string", "enum": ["Published", "Draft", "Archived"] },
        "categoryId": { "type": "string" },
        "subCategoryId": { "type": "string" },
        "publishDate": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "views": { "type": "number" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" },
        "seoKeywords": { "type": "string" },
        "imageGallery": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string" } },
        "imageCaptions": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "content", "slug", "categoryId", "publishDate", "authorName", "views"]
    },
    "Category": {
      "title": "Category",
      "description": "Discipline category for articles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "parentId": { "type": "string" }
      },
      "required": ["id", "name", "slug"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Public feedback and discussion items",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "articleId": { "type": "string" },
        "articleTitle": { "type": "string" },
        "authorName": { "type": "string" },
        "authorEmail": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected", "Spam"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "articleId", "articleTitle", "authorName", "authorEmail", "content", "status", "createdAt"]
    },
    "BreakingNews": {
      "title": "BreakingNews",
      "description": "Short immediate breaking news bulletins",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "text", "active", "createdAt"]
    },
    "UserDB": {
      "title": "UserDB",
      "description": "Admin and staff directory entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Editor", "Author"] },
        "status": { "type": "string", "enum": ["Active", "Suspended"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status", "createdAt"]
    },
    "WebSettings": {
      "title": "WebSettings",
      "description": "Dynamic web site configuration and parameters",
      "type": "object",
      "properties": {
        "logoText": { "type": "string" },
        "siteTitle": { "type": "string" },
        "contactEmail": { "type": "string" },
        "aboutText": { "type": "string" },
        "socialFacebook": { "type": "string" },
        "socialTwitter": { "type": "string" },
        "socialInstagram": { "type": "string" },
        "socialYoutube": { "type": "string" },
        "seoDescription": { "type": "string" },
        "adSenseCode": { "type": "string" },
        "analyticsCode": { "type": "string" }
      },
      "required": ["logoText", "siteTitle", "contactEmail", "aboutText"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Audit security activity logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string" },
        "ip": { "type": "string" },
        "userAgent": { "type": "string" }
      },
      "required": ["id", "userEmail", "action", "timestamp", "ip", "userAgent"]
    },
    "VideoItem": {
      "title": "VideoItem",
      "description": "Uploaded video bulletins with descriptions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "url": { "type": "string" },
        "published": { "type": "boolean" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "status": { "type": "string" },
        "views": { "type": "number" },
        "isLive": { "type": "boolean" },
        "isScheduled": { "type": "boolean" },
        "scheduledTime": { "type": "string" }
      },
      "required": ["id", "title", "description", "videoUrl", "createdAt"]
    },
    "CoverageZone": {
      "title": "CoverageZone",
      "description": "Active sections map geographic live reports coverage zone",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "status": { "type": "string" },
        "reporterName": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "x", "y", "status", "createdAt"]
    },
    "TrafficLog": {
      "title": "TrafficLog",
      "description": "Log of website visits and pageviews",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "visitorId": { "type": "string" },
        "timestamp": { "type": "string" },
        "hour": { "type": "string" },
        "path": { "type": "string" },
        "userAgent": { "type": "string" }
      },
      "required": ["visitorId", "timestamp", "hour"]
    },
    "VerificationCode": {
      "title": "VerificationCode",
      "description": "Administrative email 2FA verification code logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "code": { "type": "string" },
        "expiresAt": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "code", "expiresAt", "createdAt"]
    },
    "EBook": {
      "title": "EBook",
      "description": "Stored e-books available for download",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "description": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "coverUrl": { "type": "string" },
        "fileSize": { "type": "string" },
        "publishDate": { "type": "string" },
        "downloadCount": { "type": "number" },
        "allowDownload": { "type": "boolean" }
      },
      "required": ["id", "title", "author", "pdfUrl", "publishDate", "downloadCount", "allowDownload"]
    },
    "AdCampaign": {
      "title": "AdCampaign",
      "description": "Ad campaigns organizing multiple advertisements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "advertiserName": { "type": "string" },
        "budget": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Paused", "Ended"] },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "advertiserName", "status", "startDate", "endDate", "createdAt"]
    },
    "Ad": {
      "title": "Ad",
      "description": "An individual advertisement instance",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "advertiserName": { "type": "string" },
        "destinationUrl": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "adType": { "type": "string", "enum": ["Banner", "Video", "Popup", "Sticky", "Native"] },
        "adPlacement": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Paused", "Scheduled", "Ended"] },
        "deviceTargeting": { "type": "array", "items": { "type": "string" } },
        "categoryTargeting": { "type": "array", "items": { "type": "string" } },
        "countries": { "type": "array", "items": { "type": "string" } },
        "languages": { "type": "array", "items": { "type": "string" } },
        "campaignId": { "type": "string" },
        "impressions": { "type": "number" },
        "clicks": { "type": "number" },
        "ctr": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "title", "advertiserName", "destinationUrl", "adType", "adPlacement", "startDate", "endDate", "status", "deviceTargeting", "categoryTargeting", "impressions", "clicks", "ctr", "createdAt"]
    },
    "AdPosition": {
      "title": "AdPosition",
      "description": "Ad slot configurations on the website",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "provider": { "type": "string", "enum": ["custom", "adsense"] },
        "adsenseCode": { "type": "string" },
        "lazyLoad": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "enabled", "provider", "lazyLoad", "createdAt"]
    },
    "AdClick": {
      "title": "AdClick",
      "description": "Log of a single ad click",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adId": { "type": "string" },
        "campaignId": { "type": "string" },
        "timestamp": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "device": { "type": "string" },
        "userAgent": { "type": "string" },
        "ip": { "type": "string" }
      },
      "required": ["id", "adId", "timestamp"]
    },
    "AdImpression": {
      "title": "AdImpression",
      "description": "Log of a single ad impression",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "adId": { "type": "string" },
        "campaignId": { "type": "string" },
        "timestamp": { "type": "string" },
        "country": { "type": "string" },
        "language": { "type": "string" },
        "device": { "type": "string" },
        "userAgent": { "type": "string" },
        "ip": { "type": "string" }
      },
      "required": ["id", "adId", "timestamp"]
    }
  },
  "firestore": {
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Store all individual ads"
    },
    "/ad_campaigns/{campaignId}": {
      "schema": "AdCampaign",
      "description": "Store ad campaigns"
    },
    "/ad_positions/{positionId}": {
      "schema": "AdPosition",
      "description": "Ad slot configurations and placements"
    },
    "/ad_clicks/{clickId}": {
      "schema": "AdClick",
      "description": "Log of ad clicks for reporting"
    },
    "/ad_impressions/{impressionId}": {
      "schema": "AdImpression",
      "description": "Log of ad impressions for reporting"
    },
    "/ebooks/{ebookId}": {
      "schema": "EBook",
      "description": "Store all downloadable e-books"
    },
    "/admin_verification_codes/{codeId}": {
      "schema": "VerificationCode",
      "description": "All generated admin email verification codes"
    },
    "/traffic_logs/{logId}": {
      "schema": "TrafficLog",
      "description": "Store live anonymous website visit and traffic logs"
    },
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Store all news articles"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Catalog of category structures"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "All article user comments"
    },
    "/breaking_news/{breakingId}": {
      "schema": "BreakingNews",
      "description": "Active breaking news items"
    },
    "/users/{userId}": {
      "schema": "UserDB",
      "description": "Staff privileges details"
    },
    "/settings/{settingsId}": {
      "schema": "WebSettings",
      "description": "Global custom configs"
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Audit events feed"
    },
    "/videos/{videoId}": {
      "schema": "VideoItem",
      "description": "Uploaded video repository"
    },
    "/videoBulletins/{videoId}": {
      "schema": "VideoItem",
      "description": "Premium video bulletins feed"
    },
    "/coverage_zones/{zoneId}": {
      "schema": "CoverageZone",
      "description": "Active sections reports live map locations"
    }
  }
}
